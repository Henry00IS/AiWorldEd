{
  "name": "aiworlded",
  "private": true,
  "version": "1.0.0",
  "description": "AI World Editor — standalone 3D level editor",
  "author": "AiWorldEd",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "vitest",
    "testrun": "vitest run",
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron:start": "vite build && electron .",
    "electron:pack": "vite build && node scripts/pack_desktop.cjs"
  },
  "build": {
    "appId": "com.aiworlded.editor",
    "productName": "AI World Editor",
    "directories": {
      "output": "builds"
    },
    "files": [
      "docs/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@types/three": "^0.185.1",
    "three": "^0.185.1"
  }
}
